{
  "name": "typesense-dashboard",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "description": "A dashboard to manage self hosted or local Typesense instances.",
  "author": "Spencer Carlson",
  "homepage": "https://scarlson1.github.io/typesense-dashboard",
  "main": "./out/main/index.js",
  "engines": {
    "node": ">=20.19"
  },
  "packageManager": "pnpm@10.18.3",
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "esbuild"]
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && GENERATE_SOURCEMAP=false vite build",
    "build:sentry": "tsc -b && vite build --mode sentry",
    "build:sentry.old": "tsc -b && GENERATE_SOURCEMAP=true vite --config vite.config.sentry.js build --mode sentry",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:typecheck": "tsc -p tsconfig.vitest.json --noEmit",
    "test:e2e": "playwright test",
    "e2e:up": "docker compose -f e2e/compose.e2e.yml up -d",
    "e2e:down": "docker compose -f e2e/compose.e2e.yml down",
    "preview": "vite preview",
    "electron:dev": "electron-vite dev",
    "electron:build": "electron-vite build",
    "electron:preview": "electron-vite preview",
    "electron:pack": "electron-vite build && electron-builder",
    "electron:pack:mac": "electron-vite build && electron-builder --mac",
    "electron:pack:win": "electron-vite build && electron-builder --win",
    "electron:pack:linux": "electron-vite build && electron-builder --linux",
    "dev:docker": "docker run -dp 5173:5173 typesense-dashboard",
    "dev:compose": "docker compose up --watch --build",
    "dev:ngrok": "ngrok start typesense",
    "predeploy": "pnpm run build",
    "deploy": "gh-pages -d dist",
    "analyze:bundle": "pnpm dlx vite-bundle-visualizer"
  },
  "dependencies": {
    "@deck.gl/core": "^9.2.11",
    "@deck.gl/layers": "^9.2.11",
    "@deck.gl/react": "^9.2.11",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@fontsource/roboto": "^5.2.6",
    "@monaco-editor/react": "^4.7.0",
    "@mui/icons-material": "^9.0.1",
    "@mui/lab": "^7.0.0-beta.14",
    "@mui/material": "^9.0.1",
    "@mui/x-data-grid": "^8.28.6",
    "@mui/x-date-pickers": "^8.28.5",
    "@sentry/react": "^9.39.0",
    "@tanstack/react-form": "^1.12.3",
    "@tanstack/react-query": "^5.80.7",
    "@tanstack/react-query-devtools": "^5.80.7",
    "@tanstack/react-router": "^1.121.21",
    "@tanstack/react-router-devtools": "^1.121.21",
    "@types/mapbox-gl": "^3.4.1",
    "color": "^5.0.3",
    "csvtojson": "^2.0.14",
    "date-fns": "^4.1.0",
    "deck.gl": "^9.1.13",
    "lodash-es": "^4.17.21",
    "mapbox-gl": "^3.13.0",
    "monaco-editor": "^0.55.1",
    "path": "^0.12.7",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-error-boundary": "^6.0.0",
    "react-hot-toast": "^2.5.2",
    "react-map-gl": "^8.0.4",
    "react-swipeable": "^7.0.2",
    "typesense": "^3.0.6",
    "zod": "^4.3.6",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@playwright/test": "^1.60.0",
    "@sentry/vite-plugin": "^3.6.0",
    "@tanstack/eslint-plugin-query": "^5.78.0",
    "@tanstack/router-plugin": "^1.121.21",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.0.11",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^4.1.7",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "gh-pages": "^6.3.0",
    "globals": "^16.0.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vitest": "^4.1.7"
  }
}
